<Window x:Class="WhoLockIt.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:services="clr-namespace:WhoLockIt.Services"
        Title="WhoLockIt"
        Width="700" Height="550"
        MinWidth="520" MinHeight="400"
        WindowStartupLocation="CenterScreen"
        Style="{StaticResource ModernWindow}">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Styles/ModernStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            <Style x:Key="DropZoneStyle" TargetType="Border">
                <Setter Property="Background" Value="#1A3A5C"/>
                <Setter Property="BorderBrush" Value="#3A6A9C"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="CornerRadius" Value="8"/>
                <Style.Triggers>
                    <DataTrigger Binding="{Binding IsDropActive}" Value="True">
                        <Setter Property="Background" Value="#1E4A7A"/>
                        <Setter Property="BorderBrush" Value="#0078D4"/>
                    </DataTrigger>
                </Style.Triggers>
            </Style>
        </ResourceDictionary>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Drag-Drop Zone -->
        <Border Grid.Row="0" Margin="16,16,16,0"
                Style="{StaticResource DropZoneStyle}">
            <Grid Height="80" Background="Transparent" AllowDrop="True"
                  DragEnter="OnDragEnter" DragLeave="OnDragLeave" Drop="OnDrop">
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                    <TextBlock Text="{Binding DragHint}"
                               FontSize="14" Foreground="#888"
                               HorizontalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Path Input -->
        <Grid Grid.Row="1" Margin="16,10,16,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBox Grid.Column="0"
                     Text="{Binding FilePath, UpdateSourceTrigger=PropertyChanged}"
                     Style="{StaticResource ModernTextBox}"
                     VerticalAlignment="Center"/>
            <Button Grid.Column="1" Margin="8,0,0,0"
                    Width="44" Height="44" Padding="0" FontSize="20"
                    Style="{StaticResource PrimaryButton}"
                    Command="{Binding ScanCommand}">
                <TextBlock Text="&#x1F50D;" VerticalAlignment="Center" HorizontalAlignment="Center"/>
            </Button>
        </Grid>

        <!-- Results Grid -->
        <Border Grid.Row="2" Margin="16,12,16,0"
                Background="#1E1E1E" BorderBrush="#333333" BorderThickness="1"
                CornerRadius="8">
            <DataGrid ItemsSource="{Binding Locks}"
                      SelectedItem="{Binding SelectedLock}"
                      Style="{StaticResource ModernDataGrid}"
                      IsReadOnly="True">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[Column_Process]}"
                                        Binding="{Binding ProcessName}" Width="2*"/>
                    <DataGridTextColumn Header="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[Column_PID]}"
                                        Binding="{Binding Pid}" Width="*"/>
                    <DataGridTextColumn Header="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[Column_Type]}"
                                        Binding="{Binding LockType}" Width="*"/>
                    <DataGridTextColumn Header="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[Column_Source]}"
                                        Binding="{Binding Source}" Width="*"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <!-- Action Buttons -->
        <StackPanel Grid.Row="3" Orientation="Horizontal"
                    Margin="16,12,16,0">
            <Button Content="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[UnlockSelected_Button]}"
                    Style="{StaticResource SecondaryButton}"
                    Command="{Binding UnlockSelectedCommand}"
                    Margin="0,0,6,0"/>
            <Button Content="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[UnlockAll_Button]}"
                    Style="{StaticResource SecondaryButton}"
                    Command="{Binding UnlockAllCommand}"
                    Margin="0,0,6,0"/>
            <Button Content="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[UnlockAllAndDelete_Button]}"
                    Style="{StaticResource DangerButton}"
                    Command="{Binding UnlockAllAndDeleteCommand}"
                    Margin="0,0,6,0"/>
            <Button Content="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[CopyResults_Button]}"
                    Style="{StaticResource SecondaryButton}"
                    Command="{Binding CopyResultsCommand}"/>
        </StackPanel>

        <!-- Bottom Bar: status + context menu + topmost + language -->
        <Grid Grid.Row="4" Margin="16,10,16,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="{Binding StatusText}"
                       Foreground="#999" FontSize="12" VerticalAlignment="Center"/>
            <Button Grid.Column="1" Content="{Binding ContextMenuButtonText}"
                    Style="{StaticResource LinkButton}"
                    Command="{Binding ToggleContextMenuCommand}"
                    Margin="0,0,12,0"/>
            <Button Grid.Column="2" Content="{Binding TopmostText}"
                    Style="{StaticResource LinkButton}"
                    Command="{Binding ToggleTopmostCommand}"
                    Margin="0,0,12,0"/>
            <Button Grid.Column="3" Content="{Binding LanguageToggleText}"
                    Style="{StaticResource LinkButton}"
                    Command="{Binding ToggleLanguageCommand}"
                    Margin="0,0,12,0"/>
        </Grid>
    </Grid>
</Window>
